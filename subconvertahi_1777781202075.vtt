319
00:20:55.339 --> 00:20:57.758
[grunts. panting]

320
00:20:59.801 --> 00:21:01.303
[exclaims]

321
00:21:02.304 --> 00:21:04.473
[exclaims. grunting]

322
00:21:09.061 --> 00:21:10.187
[coughs]

323
