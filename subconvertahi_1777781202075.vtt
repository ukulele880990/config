311
00:20:25.726 --> 00:20:27.227
[growls]

312
00:20:27.978 --> 00:20:30.731
[roaring]

313
00:20:30.814 --> 00:20:32.274
- [shrieking]
- [Cate whimpers]

314
00:20:33.317 --> 00:20:35.110
[panting]

315
00:20:43.660 --> 00:20:44.870
[shrieking]

316
00:20:44.953 --> 00:20:46.830
[panting]

317
00:20:46.914 --> 00:20:47.915
