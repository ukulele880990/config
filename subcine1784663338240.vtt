{\an8}♪ ♪

983
01:38:14.291 --> 01:38:16.291
{\an8}♪ ♪

984
01:38:46.541 --> 01:38:48.541
{\an8}♪ ♪

985
01:39:01.666 --> 01:39:04.165
{\an8}

986
01:39:04.166 --> 01:39:06.250
{\an8}

987
01:39:36.041 --> 01:39:38.041
{\an8}♪ ♪

988
