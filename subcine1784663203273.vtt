452
00:34:34.840 --> 00:34:36.300
<font color="#ffff54">No!</font>

453
00:34:36.600 --> 00:34:36.900
<font color="#ffff54">No!</font>

454
00:34:37.280 --> 00:34:37.460
<font color="#ffff54">No!</font>

455
00:34:39.460 --> 00:34:40.260
<font color="#ffff54">No!</font>

456
00:34:40.360 --> 00:34:40.540
<font color="#ffff54">Run out!</font>

